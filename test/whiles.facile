a := 0;
b := 1;
c := 0;

while c # 10 do
	c := c + 1;
endwhile

print c;

while true do
	print a;
	break
end

while c # 5 do
	c := c - 1;
	continue
	print b;
end

print c;

while c # 0 do

	while true do
		c := c - 1;
		d := 0;

		while d # 3 do
			d := d + 1;
			continue
			print b;
		endwhile
		break

	endwhile
endwhile

print c;
